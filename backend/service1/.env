# Generer ny SECRET_KEY med: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=INDSÆT_NY_HER_MINIMUM_32_TEGN

# Skift dette til et stærkt kodeord (min 12 tegn, store+små bogstaver+tal)
ADMIN_PASSWORD=INDSÆT_STÆRKT_KODEORD_HER

# Din Neon-database (skift kodeord på neon.tech hvis det gamle er eksponeret)
DATABASE_URL=postgresql://neondb_owner:NYTPASSWORD@ep-raspy-math-a2qmxohl-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Admin-brugerens e-mail (bruges ved oprettelse)
ADMIN_EMAIL=din@email.dk

# Sæt til "production" for at skjule /docs og /openapi.json
ENVIRONMENT=production

# Frontend origin(s) adskilt med komma
ALLOWED_ORIGINS=https://infoskaerm-frontend.netlify.app
